<Project Sdk="Microsoft.NET.Sdk">

  <ItemGroup>
    <ProjectReference Include="..\BackupApp.Core\BackupApp.Core.csproj" />
  </ItemGroup>

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <UseWindowsForms>true</UseWindowsForms>
    <ImplicitUsings>enable</ImplicitUsings>
    <ApplicationIcon>..\..\installer\assets\app.ico</ApplicationIcon>
    <AssemblyTitle>BackupApp</AssemblyTitle>
    <Product>BackupApp</Product>
    <Version>1.0.0</Version>
    <Company>BackupApp</Company>
    <!-- Ship no debug symbols in Release publishes -->
    <DebugType Condition="'$(Configuration)' == 'Release'">none</DebugType>
  </PropertyGroup>

</Project>